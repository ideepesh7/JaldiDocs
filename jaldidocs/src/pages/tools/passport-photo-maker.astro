---
// src/pages/tools/passport-photo-maker.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import PassportPhotoMaker from '../../components/tools/PassportPhotoMaker';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';
import { PASSPORT_FAQS } from '../../data/faqs';

const relatedTools = TOOLS.filter(t => ['image-resize', 'image-compress', 'aadhaar-photo-resize', 'pan-card-photo-resize'].includes(t.id));
---

<ToolLayout
  title="Passport Photo Maker India - 35x45mm Photo Online Free | JaldiDocs"
  description="Create standard Indian passport photos (35×45mm), 2×2 inch visa photos and custom sizes online for free. Generate a printable sheet of photos. No signup, browser-based."
  canonical="/tools/passport-photo-maker/"
>
  <ToolHeader
    client:load
    name="Passport Photo Maker"
    description="Create correctly sized passport and visa photos in your browser. Choose Indian passport (35×45mm), 2×2 inch, or a custom size. Download as JPG or generate a printable sheet."
    breadcrumb={[{ label: 'Image Tools', href: '/#image-tools' }, { label: 'Passport Photo Maker', href: '/tools/passport-photo-maker/' }]}
  />

  <PassportPhotoMaker client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>Indian Passport Photo Requirements</h2>
      <p>
        For Indian passport applications, the standard photo size is <strong>35mm × 45mm</strong> with a
        plain white background. The face should cover about 70–80% of the frame. Both eyes must be open
        and clearly visible. The photo must be recent (taken within the last 6 months).
      </p>
      <p>
        Always verify the latest requirements on the official Passport Seva portal
        (passportindia.gov.in) before submitting your application, as requirements can change.
      </p>

      <h2>How to Use This Tool</h2>
      <ol class="list-decimal list-inside space-y-1.5 my-3 text-sm text-secondary">
        <li>Upload a clear, front-facing photo with good lighting</li>
        <li>Select your target photo size (Indian Passport, 2×2 inch, or custom)</li>
        <li>Choose background colour (white is standard for most documents)</li>
        <li>Click "Generate Passport Photo" to preview the result</li>
        <li>Download as JPG for digital use or as a PDF sheet for printing</li>
      </ol>

      <h2>Photo Requirements for Common Indian Documents</h2>
      <ul>
        <li><strong>Passport:</strong> 35×45mm, white background, plain light clothing</li>
        <li><strong>Aadhaar:</strong> Colour photo, white/light background, no cap or sunglasses</li>
        <li><strong>PAN Card:</strong> 3.5×3.5cm, white background, recent photo</li>
        <li><strong>Visa (US, UK, Schengen):</strong> 2×2 inch (50×50mm), white background</li>
        <li><strong>Exam forms (SSC, UPSC, IBPS):</strong> Typically 3.5×4.5cm, under 50–100KB</li>
        <li><strong>Driving licence:</strong> Check RTO requirements — usually 3.5×4.5cm</li>
      </ul>

      <h2>Tips for a Good Passport Photo</h2>
      <ul>
        <li>Take the photo in natural light near a window — avoid harsh flash</li>
        <li>Use a plain white or light wall as background if possible</li>
        <li>Face the camera directly, with a neutral expression</li>
        <li>Remove glasses (as per recent Indian passport rules)</li>
        <li>Wear plain clothing without busy patterns</li>
        <li>Keep hair away from the face so both ears are visible</li>
      </ul>
    </div>

    <FAQSection client:load faqs={PASSPORT_FAQS} title="Passport Photo — FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="passport-photo-maker" />
  </div>
</ToolLayout>
