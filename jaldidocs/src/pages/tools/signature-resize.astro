---
// src/pages/tools/signature-resize.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import SignatureResize from '../../components/tools/SignatureResize';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';

const faqs = [
  { question: 'What size should a signature be for exam forms?', answer: 'Most government exam portals require a scanned signature between 140×60 px to 200×80 px and under 20KB–50KB. Always check the specific exam notification for the exact requirement.' },
  { question: 'Should I use JPG or PNG for my signature?', answer: 'For most exam and government portals, JPG is the required format. Use PNG only if the portal specifically asks for it or if you need a transparent background.' },
  { question: 'How do I scan my signature?', answer: 'Sign on white paper with a black or dark blue pen. Use your phone camera in good light, or use a scanner app. Crop close to the signature, removing as much white space around it as possible before uploading.' },
  { question: 'My signature file is too large even after compression. What should I do?', answer: 'Try reducing the target size further (e.g. Under 20KB) and ensure you select JPG as the output format. If the signature still exceeds the limit, also reduce the dimensions using the preset sizes.' },
];

const relatedTools = TOOLS.filter(t => ['image-resize', 'image-compress', 'passport-photo-maker', 'aadhaar-photo-resize'].includes(t.id));
---

<ToolLayout
  title="Signature Resize Online Free - Under 20KB for Exam Forms | JaldiDocs"
  description="Resize your scanned signature for exam forms (SSC, UPSC, IBPS, NEET) to 140x60, 160x60, 200x80 px and compress under 20KB or 50KB. Browser-based, no upload."
  canonical="/tools/signature-resize/"
>
  <ToolHeader
    client:load
    name="Signature Resize"
    description="Resize your scanned signature to standard exam form sizes and compress it to under 20KB, 50KB or 100KB. Perfect for SSC, UPSC, IBPS, NEET, and other government exam portals."
    breadcrumb={[{ label: 'Student Tools', href: '/#student-tools' }, { label: 'Signature Resize', href: '/tools/signature-resize/' }]}
  />

  <SignatureResize client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>Why Resize Your Signature?</h2>
      <p>
        Government exam portals and job application websites require scanned signatures in very specific
        sizes and file sizes. Uploading the wrong size causes form rejection. This tool resizes and compresses
        your signature image to meet common requirements without needing any software.
      </p>

      <h2>Common Signature Size Requirements</h2>
      <ul>
        <li><strong>SSC CGL, CHSL, MTS:</strong> 140×60 px, under 20KB, JPG/JPEG</li>
        <li><strong>IBPS PO, Clerk, SO:</strong> 140×60 px, 10KB–20KB, JPG</li>
        <li><strong>SBI PO / Clerk:</strong> 140×60 px, under 20KB</li>
        <li><strong>UPSC CSE:</strong> Check the official notification — varies by year</li>
        <li><strong>NEET UG / JEE Main:</strong> Typically 160×60 px or 200×80 px, under 30KB</li>
        <li><strong>Railway NTPC / ALP:</strong> Usually under 30KB</li>
        <li><strong>State PSC portals:</strong> Varies — check the specific notification</li>
      </ul>

      <h2>How to Get the Best Signature Scan</h2>
      <ol class="list-decimal list-inside space-y-1.5 my-3 text-sm text-secondary">
        <li>Sign on white A4 paper using a black or dark blue pen</li>
        <li>Keep the signature compact — avoid very large signatures that spread across the page</li>
        <li>Place the paper near a window for even, diffused natural light</li>
        <li>Take a close photo with your phone camera, or scan it</li>
        <li>Crop the image tightly around the signature before uploading</li>
        <li>Use this tool to resize and compress to the required dimensions</li>
      </ol>
    </div>

    <FAQSection client:load faqs={faqs} title="Signature Resize — FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="signature-resize" />
  </div>
</ToolLayout>
