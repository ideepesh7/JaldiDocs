---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import WordCounter from '../../components/tools/WordCounter';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { getRelatedTools } from '../../lib/relatedTools';

const faqs = [
  { question: 'Does the word counter upload my text?', answer: 'No. The counting happens in your browser. Your text is not sent to JaldiDocs.' },
  { question: 'What is counted as a word?', answer: 'Words are counted by separating text using spaces and line breaks, which works well for most English writing tasks.' },
  { question: 'Can I use this for resumes and essays?', answer: 'Yes. It is useful for resumes, essays, statement of purpose drafts, bios and application text limits.' },
];

const relatedTools = getRelatedTools('word-counter');
---

<ToolLayout
  title="Word Counter Online - Count Words and Characters | JaldiDocs"
  description="Count words, characters, sentences, paragraphs and reading time online. Free private word counter for resumes, essays and applications."
  canonical="/tools/word-counter/"
>
  <ToolHeader
    client:load
    name="Word Counter"
    description="Count words, characters, sentences, paragraphs and estimated reading time for essays, resumes, bios and form fields."
    breadcrumb={[{ label: 'Student Tools', href: '/#student-tools' }, { label: 'Word Counter', href: '/tools/word-counter/' }]}
  />

  <WordCounter client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />
    <div class="prose-tool mt-4">
      <h2>Private word and character counter</h2>
      <p>
        Many application forms, scholarship portals and social platforms have strict text limits. This tool
        helps you check word count, character count, sentence count and reading time before submission.
      </p>
      <h2>Useful for</h2>
      <ul>
        <li>Resume summaries and LinkedIn bios</li>
        <li>Essays, SOPs and scholarship answers</li>
        <li>Product descriptions and social posts</li>
        <li>Application forms with character limits</li>
      </ul>
    </div>
    <FAQSection client:load faqs={faqs} title="Word Counter FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="word-counter" />
  </div>
</ToolLayout>
