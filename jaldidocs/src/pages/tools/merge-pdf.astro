---
// src/pages/tools/merge-pdf.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import MergePdf from '../../components/tools/MergePdf';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';
import { MERGE_PDF_FAQS } from '../../data/faqs';

const relatedTools = TOOLS.filter(t => ['jpg-to-pdf', 'pdf-compressor', 'image-resize', 'invoice-maker'].includes(t.id));
---

<ToolLayout
  title="Merge PDF Files Online Free - Combine PDFs Without Upload | JaldiDocs"
  description="Merge multiple PDF files into one PDF online for free. No signup, no server upload — PDFs are combined entirely in your browser using pdf-lib."
  canonical="/tools/merge-pdf"
>
  <ToolHeader
    client:load
    name="Merge PDF"
    description="Combine multiple PDF files into one document. Upload, reorder, and merge PDFs entirely in your browser. Your files are never uploaded to any server."
    breadcrumb={[{ label: 'PDF Tools', href: '/#pdf-tools' }, { label: 'Merge PDF', href: '/tools/merge-pdf' }]}
  />

  <MergePdf client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>Merge PDFs Without Uploading</h2>
      <p>
        This tool merges your PDF files entirely in your browser. No file is sent to any server. This makes
        it safe for combining sensitive documents such as salary slips, offer letters, ID proofs, or
        financial statements.
      </p>

      <h2>Common Use Cases</h2>
      <ul>
        <li>Combining multiple salary slips into one PDF for a loan application</li>
        <li>Merging an offer letter, ID proof and address proof for KYC</li>
        <li>Combining multiple marksheets or certificates for college applications</li>
        <li>Joining chapter-wise PDFs into a single study material document</li>
        <li>Merging invoices for an accounting or audit document set</li>
      </ul>

      <h2>How to Merge PDFs</h2>
      <ol class="list-decimal list-inside space-y-1.5 my-3 text-sm text-secondary">
        <li>Upload all the PDF files you want to merge</li>
        <li>Use the arrows to set the correct order of the PDFs</li>
        <li>Click "Merge PDFs & Download" — the merged PDF downloads automatically</li>
      </ol>

      <h2>Limitations</h2>
      <ul>
        <li>Password-protected PDFs cannot be merged — remove the password first</li>
        <li>Very large files (combined over 100MB) may be slow on older devices or slow connections</li>
        <li>Some corrupted or non-standard PDF files may fail — use a standard PDF creator or printer driver to recreate the file if needed</li>
      </ul>
    </div>

    <FAQSection client:load faqs={MERGE_PDF_FAQS} title="Merge PDF — FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="merge-pdf" />
  </div>
</ToolLayout>
