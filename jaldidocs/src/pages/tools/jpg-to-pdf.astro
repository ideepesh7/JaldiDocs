---
// src/pages/tools/jpg-to-pdf.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import JpgToPdf from '../../components/tools/JpgToPdf';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';

const faqs = [
  { question: 'Is JPG to PDF tool free?', answer: 'Yes, this tool is completely free and works directly in your browser.' },
  { question: 'Do I need to upload files?', answer: 'No uploads required. Everything works locally in your browser for privacy.' },
  { question: 'Can I convert multiple images?', answer: 'Yes, you can convert multiple JPG, PNG, or WEBP images into one PDF.' },
  { question: 'Is it safe for documents?', answer: 'Yes, files are not sent to any server, so it is fully secure.' },
];

const relatedTools = TOOLS.filter(t =>
  ['merge-pdf', 'pdf-compressor', 'image-resize', 'image-compress'].includes(t.id)
);
---

<ToolLayout
  title="JPG to PDF Converter Online Free | Convert Images to PDF - JaldiDocs"
  description="Convert JPG, PNG and WEBP images to PDF online for free. No signup required. Fast, secure and works completely in your browser."
  canonical="/tools/jpg-to-pdf"
>
  <ToolHeader
    client:load
    name="JPG to PDF Converter"
    description="Convert multiple images (JPG, PNG, WEBP) into a single PDF file instantly. No upload, no signup."
    breadcrumb={[
      { label: 'PDF Tools', href: '/#pdf-tools' },
      { label: 'JPG to PDF', href: '/tools/jpg-to-pdf' }
    ]}
  />

  <JpgToPdf client:load />

  <div slot="seo-content">

    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">

      <h2>Free JPG to PDF Converter Online</h2>
      <p>
        Convert your images into a single PDF file instantly. This tool supports JPG, PNG, and WEBP formats
        and works completely in your browser without uploading files anywhere.
      </p>

      <h2>Why Use This Tool?</h2>
      <ul>
        <li>100% free and browser-based</li>
        <li>No file upload required</li>
        <li>Fast and secure conversion</li>
        <li>Works on mobile and desktop</li>
        <li>Perfect for document submission</li>
      </ul>

      <h2>Common Uses in India</h2>
      <ul>
        <li>Aadhaar, PAN, and KYC document submission</li>
        <li>College admission form documents</li>
        <li>Bank verification and applications</li>
        <li>Government online submissions</li>
      </ul>

      <h2>How to Use</h2>
      <ol>
        <li>Upload JPG, PNG or WEBP images</li>
        <li>Reorder images if needed</li>
        <li>Click convert button</li>
        <li>Download your PDF instantly</li>
      </ol>

      <h2>Pro Tips</h2>
      <ul>
        <li>Use A4 format for official documents</li>
        <li>Compress large images before converting</li>
        <li>Use JPG for smaller file size PDFs</li>
      </ul>

    </div>

    <FAQSection client:load faqs={faqs} title="Frequently Asked Questions" />
    <RelatedTools client:load tools={relatedTools} currentId="jpg-to-pdf" />

  </div>
</ToolLayout>