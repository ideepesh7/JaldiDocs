---
// src/pages/tools/rent-receipt-generator.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import RentReceiptGenerator from '../../components/tools/RentReceiptGenerator';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';

const faqs = [
  { question: 'Is this rent receipt valid for HRA exemption?', answer: 'The rent receipt generated here follows a standard format suitable for HRA claims. However, for tax exemption purposes, consult your employer\'s HR or a CA. Rent receipts above ₹1 lakh per year require the landlord\'s PAN.' },
  { question: 'Does the landlord need to sign the receipt?', answer: 'For HRA claims, a signed receipt is generally required. Print the receipt and have your landlord sign it, or obtain their digital signature if your employer accepts it.' },
  { question: 'Is my data saved anywhere?', answer: 'Your data is only saved in your browser\'s localStorage if you click "Save Draft". Nothing is sent to any server. You can clear your browser data or click "Clear" to remove it.' },
  { question: 'Can I generate receipts for multiple months?', answer: 'Yes. Change the month and receipt number for each month, click "Download PDF" separately for each. Optionally save a draft to preserve your landlord and address details across months.' },
];

const relatedTools = TOOLS.filter(t => ['invoice-maker', 'merge-pdf', 'pdf-compressor', 'jpg-to-pdf'].includes(t.id));
---

<ToolLayout
  title="Rent Receipt Generator Online Free - Download PDF | JaldiDocs"
  description="Generate professional rent receipts for HRA tax claims. Enter tenant, landlord and rent details, then download as PDF or print. Free, no signup, browser-based."
  canonical="/tools/rent-receipt-generator"
>
  <ToolHeader
    client:load
    name="Rent Receipt Generator"
    description="Generate a professional rent receipt in seconds. Fill in tenant, landlord and payment details, preview instantly, and download as a PDF. Data is saved only in your browser."
    breadcrumb={[{ label: 'Business Tools', href: '/#business-tools' }, { label: 'Rent Receipt Generator', href: '/tools/rent-receipt-generator' }]}
  />

  <RentReceiptGenerator client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>What is a Rent Receipt?</h2>
      <p>
        A rent receipt is a document issued by a landlord to a tenant confirming that rent has been paid.
        In India, rent receipts are commonly used to claim House Rent Allowance (HRA) exemption under
        Section 10(13A) of the Income Tax Act.
      </p>

      <h2>When Do You Need a Rent Receipt?</h2>
      <ul>
        <li>To claim HRA exemption while filing income tax returns (ITR)</li>
        <li>To submit proof of rent to your employer for salary processing</li>
        <li>As a legal record of rent payment between tenant and landlord</li>
        <li>For bank loan applications that require proof of residence</li>
      </ul>

      <h2>HRA Exemption Rules (General Guide)</h2>
      <ul>
        <li>HRA is exempt under Section 10(13A) if you live in rented accommodation</li>
        <li>If annual rent exceeds ₹1,00,000, the landlord's PAN is mandatory</li>
        <li>You cannot claim HRA if you own the property you live in</li>
        <li>Rent receipts should ideally be monthly and signed by the landlord</li>
        <li>Always consult a CA or tax professional for personalised advice</li>
      </ul>

      <h2>Important Disclaimer</h2>
      <p>
        JaldiDocs provides this tool for convenience only. This is not legal or tax advice. For accurate
        HRA claims and tax compliance, consult a Chartered Accountant or a tax professional. The format
        of rent receipts required by employers or tax authorities may differ.
      </p>
    </div>

    <FAQSection client:load faqs={faqs} title="Rent Receipt — FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="rent-receipt-generator" />
  </div>
</ToolLayout>
