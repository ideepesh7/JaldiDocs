---
// src/pages/tools/jpg-to-pdf.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import JpgToPdf from '../../components/tools/JpgToPdf';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';

const faqs = [
  { question: 'Is JPG to PDF converter free?', answer: 'Yes, this tool is completely free to use with no signup required.' },
  { question: 'Is my data safe?', answer: 'Yes, everything runs in your browser. No files are uploaded to any server.' },
  { question: 'Can I use it on mobile?', answer: 'Yes, the tool works smoothly on Android and iPhone browsers.' },
  { question: 'What formats are supported?', answer: 'You can convert JPG, JPEG, PNG, and WEBP images into PDF.' },
];

const relatedTools = TOOLS.filter(t =>
  ['merge-pdf', 'pdf-compressor', 'image-resize', 'image-compress'].includes(t.id)
);
---

<ToolLayout
  title="JPG to PDF Converter Online Free | Convert Images to PDF - JaldiDocs"
  description="Convert JPG, JPEG, PNG and WEBP images to PDF online for free. No signup, no upload, works instantly in browser. Fast and secure image to PDF tool."
  canonical="/tools/jpg-to-pdf"
>
  <ToolHeader
    client:load
    name="JPG to PDF Converter"
    description="Convert JPG, JPEG, PNG and WEBP images into a single PDF file instantly. Free online tool with no login or upload required."
    breadcrumb={[
      { label: 'Home', href: '/' },
      { label: 'Tools', href: '/#tools' },
      { label: 'JPG to PDF', href: '/tools/jpg-to-pdf' }
    ]}
  />

  <JpgToPdf client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">

      <h2>Free JPG to PDF Converter Online</h2>
      <p>
        Convert your images into PDF files instantly using this free online tool. No installation,
        no signup, and no file upload required. Everything works directly in your browser, ensuring
        privacy and fast processing.
      </p>

      <h2>Why Use This Tool?</h2>
      <ul>
        <li>100% free JPG to PDF conversion</li>
        <li>No upload — works inside browser</li>
        <li>Fast and mobile friendly</li>
        <li>Supports JPG, JPEG, PNG, WEBP</li>
        <li>Perfect for official documents and forms</li>
      </ul>

      <h2>Common Uses in India</h2>
      <ul>
        <li>Aadhaar, PAN, and ID document submission</li>
        <li>College admission document upload</li>
        <li>Bank KYC and verification files</li>
        <li>Job application document merging</li>
        <li>Scanned notes or assignments in PDF format</li>
      </ul>

      <h2>How to Convert JPG to PDF</h2>
      <ol class="list-decimal list-inside space-y-1.5 my-3 text-sm text-secondary">
        <li>Upload your images using the upload button</li>
        <li>Reorder images if needed using arrows</li>
        <li>Select page size (A4 recommended)</li>
        <li>Click "Create PDF" and download instantly</li>
      </ol>

      <h2>Tips for Best Results</h2>
      <ul>
        <li>Use A4 size for official documents</li>
        <li>Use high-quality images for better PDF output</li>
        <li>Compress images first if file size is large</li>
        <li>Keep correct order before conversion</li>
      </ul>

    </div>

    <FAQSection client:load faqs={faqs} title="Frequently Asked Questions" />
    <RelatedTools client:load tools={relatedTools} currentId="jpg-to-pdf" />
  </div>
</ToolLayout>