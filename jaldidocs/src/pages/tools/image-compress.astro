---
// src/pages/tools/jpg-to-pdf.astro

import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import JpgToPdf from '../../components/tools/JpgToPdf';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { TOOLS } from '../../data/tools';

const siteUrl = 'https://jaldidocs.pages.dev';

const faqs = [
  {
    question: 'How many images can I convert at once?',
    answer: 'You can add multiple images. For best performance, keep total size under 50MB.'
  },
  {
    question: 'Will image quality be reduced?',
    answer: 'No major quality loss. Images are optimized for best PDF balance.'
  },
  {
    question: 'Can I reorder images?',
    answer: 'Yes, drag or use arrows to reorder before conversion.'
  },
  {
    question: 'Which page size should I use?',
    answer: 'A4 is best for documents, Fit-to-image for exact size output.'
  }
];

const relatedTools = TOOLS
  ? TOOLS.filter(t =>
      ['merge-pdf', 'pdf-compressor', 'image-resize', 'image-compress'].includes(t.id)
    )
  : [];
---

<ToolLayout
  title="JPG to PDF Converter Online Free | JaldiDocs"
  description="Convert JPG, PNG, and WEBP images into a single PDF instantly in your browser. No upload, no signup, 100% free tool."
  canonical="/tools/jpg-to-pdf"
>
  <ToolHeader
    client:load
    name="JPG to PDF Converter"
    description="Convert images into a single PDF file directly in your browser. Fast, secure, and free."
    breadcrumb={[
      { label: 'PDF Tools', href: '/#pdf-tools' },
      { label: 'JPG to PDF', href: '/tools/jpg-to-pdf' }
    ]}
  />

  <JpgToPdf client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>Convert Images to PDF Online</h2>
      <p>
        Convert JPG, PNG, and WEBP images into a single PDF file directly in your browser.
        No uploads, no signup, completely private processing.
      </p>

      <h2>Use Cases</h2>
      <ul>
        <li>College documents & marksheets</li>
        <li>Bank KYC submissions</li>
        <li>Government forms</li>
        <li>Scanned documents merging</li>
      </ul>

      <h2>Steps</h2>
      <ol>
        <li>Select images</li>
        <li>Reorder if needed</li>
        <li>Choose settings</li>
        <li>Download PDF</li>
      </ol>

      <h2>Tips</h2>
      <ul>
        <li>Use A4 for official documents</li>
        <li>Compress large images first</li>
        <li>Use JPG for smaller file size</li>
      </ul>
    </div>

    <FAQSection client:load faqs={faqs} title="FAQs - JPG to PDF" />
    <RelatedTools client:load tools={relatedTools} currentId="jpg-to-pdf" />
  </div>
</ToolLayout>