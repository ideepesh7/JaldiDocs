---
// src/pages/tools/image-compress.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolHeader from '../../components/ui/ToolHeader';
import ImageCompress from '../../components/tools/ImageCompress';
import FAQSection from '../../components/ui/FAQSection';
import RelatedTools from '../../components/ui/RelatedTools';
import AdSlot from '../../components/ui/AdSlot';
import { getRelatedTools } from '../../lib/relatedTools';
import { IMAGE_COMPRESS_FAQS } from '../../data/faqs';

const relatedTools = getRelatedTools('image-compress');
---

<ToolLayout
  title="Compress Image Online Free - Under 50KB, 100KB, 200KB | JaldiDocs"
  description="Compress JPG, PNG and WEBP images to reduce file size. Target under 50KB, 100KB or 200KB. All compression happens in your browser — your photo is never uploaded."
  canonical="/tools/image-compress/"
>
  <ToolHeader
    client:load
    name="Image Compress"
    description="Reduce the file size of your JPG, PNG or WEBP image. Set a target size in KB or adjust the quality slider. Works entirely in your browser — nothing is uploaded."
    breadcrumb={[{ label: 'Image Tools', href: '/#image-tools' }, { label: 'Image Compress', href: '/tools/image-compress/' }]}
  />

  <ImageCompress client:load />

  <div slot="seo-content">
    <AdSlot client:load className="mb-10" />

    <div class="prose-tool mt-4">
      <h2>Why Compress Images?</h2>
      <p>
        Many Indian government portals, exam registration systems, and job application websites have strict
        file size limits for photo uploads — commonly under 50KB, 100KB or 200KB. This tool lets you
        compress your image to meet those limits without needing any software.
      </p>

      <h2>How to Compress an Image</h2>
      <ol class="list-decimal list-inside space-y-1.5 my-3 text-sm text-secondary">
        <li>Upload your JPG, PNG or WEBP image using the file picker or drag and drop</li>
        <li>Choose a quick target size preset (50KB, 100KB, 200KB, 500KB) or enter a custom target</li>
        <li>Or skip the target and use the quality slider for manual control</li>
        <li>Click "Compress Image" — see the before/after size comparison</li>
        <li>Download the compressed image</li>
      </ol>

      <h2>Compression Size Guide for Indian Portals</h2>
      <ul>
        <li><strong>SSC CGL, CHSL, MTS:</strong> Candidate photo under 50KB</li>
        <li><strong>UPSC CSE, CDS:</strong> Photo under 40KB–300KB depending on portal</li>
        <li><strong>Banking (IBPS, SBI PO):</strong> Photo under 50KB, Signature under 20KB</li>
        <li><strong>NEET, JEE, CUET:</strong> Typically 10KB–200KB — check notification</li>
        <li><strong>Passport Seva:</strong> Photo under 1MB, face clearly visible</li>
        <li><strong>Railway NTPC / ALP:</strong> Photo under 100KB</li>
      </ul>

      <h2>Tips</h2>
      <ul>
        <li>JPG compression is lossy — slight quality loss is normal and usually invisible at print or screen size</li>
        <li>PNG files are larger but lossless — best for signatures and screenshots</li>
        <li>Very small target sizes (under 20KB) may require reducing dimensions as well — use Image Resize first</li>
        <li>A photo taken in good lighting compresses much better than a dark or blurry photo</li>
      </ul>
    </div>

    <FAQSection client:load faqs={IMAGE_COMPRESS_FAQS} title="Image Compress — FAQs" />
    <RelatedTools client:load tools={relatedTools} currentId="image-compress" />
  </div>
</ToolLayout>
